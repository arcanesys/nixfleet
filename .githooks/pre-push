#!/usr/bin/env bash
set -euo pipefail

# Pre-push: eval tests + cargo test (fast, ~15s)
# Full validate (host builds) runs in CI, not here
#
# `--no-cache` is deliberate: see the rationale in .githooks/pre-commit.
# Short version: treefmt's per-inode cache can hide drift that CI's
# empty cache surfaces, producing the "passed locally, failed in CI"
# class of Format check regression.
echo "=== Checking formatting ==="
nix fmt -- --no-cache --fail-on-change || {
  echo "Formatting issues. Run: nix fmt -- --no-cache"
  exit 1
}

echo "=== Eval tests ==="
# Per-host eval-* checks were removed during the framework decoupling
# (defined against an example fleet that no longer ships). The
# mkFleet-eval-tests check exercises the lib-level harness with every
# fixture under tests/lib/mk-fleet/.
nix build ".#checks.x86_64-linux.mkFleet-eval-tests" --no-link 2>/dev/null || {
  echo "Eval test mkFleet-eval-tests failed."
  exit 1
}

echo "=== Rust workspace tests ==="
if [[ -f Cargo.toml ]]; then
  nix develop --command cargo nextest run --workspace 2>&1 || {
    echo "Rust tests failed."
    exit 1
  }
fi

# Clippy gate. Catches the lint class that landed via 166b898 (clippy
# hygiene) - slipped in because operator CI was broken and the previous
# pre-push only ran nextest (functional tests, not lints). Same flags
# as `validate --rust` (modules/apps.nix) so local gate matches CI.
echo "=== Clippy ==="
if [[ -f Cargo.toml ]]; then
  nix develop --command cargo clippy --workspace --all-targets -- -D warnings 2>&1 || {
    echo "Clippy lints. Run: cargo clippy --workspace --all-targets -- -D warnings"
    exit 1
  }
fi

echo "All pre-push checks passed."
